<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.autopilot.daemon</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/yazannajem/Desktop/AI Project/services/autopilot_daemon.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/yazannajem/Desktop/AI Project</string>

    <key>StandardOutPath</key>
    <string>/tmp/autopilot_daemon.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/autopilot_daemon.stderr.log</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>SessionCreate</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>300</integer>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/yazannajem</string>
    </dict>
</dict>
</plist>
